<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="postSplashScreenTheme">@style/Theme.SchlafGut</item>
    </style>

    <style name="Theme.SchlafGut" parent="android:Theme.Material.NoActionBar">
        <!-- We use enableEdgeToEdge() in MainActivity, so these are handled there -->
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>
</resources>
